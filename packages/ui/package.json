{
  "name": "@page-builder/ui",
  "version": "1.0.0",
  "description": "Reusable UI component library for Page Builder",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.js",
      "default": "./dist/index.mjs"
    },
    "./styles": "./src/styles.js",
    "./*": "./src/*/index.jsx"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "lucide-react": "^0.344.0",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "sass": "^1.98.0",
    "vite": "^8.0.0"
  }
}
