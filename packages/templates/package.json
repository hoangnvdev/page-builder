{
  "name": "@page-builder/templates",
  "version": "1.0.0",
  "description": "Page builder template library",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.js",
      "default": "./dist/index.mjs"
    },
    "./styles": {
      "development": "./src/styles.js",
      "default": "./dist/templates.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@page-builder/ui": "workspace:*",
    "prop-types": "^15.8.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.0"
  }
}
