{
  "name": "page-builder-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "description": "Page Builder monorepo - UI components, templates, and application",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "build:ui": "pnpm --filter @page-builder/ui build",
    "build:templates": "pnpm --filter @page-builder/templates build",
    "build:app": "pnpm --filter @page-builder/app build",
    "start": "pnpm --filter @page-builder/app start",
    "preview": "pnpm --filter @page-builder/app preview",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.24.0",
    "sass": "^1.98.0",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "react-i18next": "^16.5.8"
  }
}
